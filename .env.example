# yacht — example configuration
#
# Copy this file to `.env` (ignored by git) for local runs, or deploy the
# populated values to /etc/yacht/config.env on the VPS. Every variable
# documented in SPEC.md § Configuration appears here.
#
# Secrets are marked with <placeholder> — replace them with real values and
# never commit the filled-in file.

# ---------------------------------------------------------------------------
# Shared (required by both binaries unless a default is noted)
# ---------------------------------------------------------------------------

# Public URL of the share-hosting subdomain. Used when building share links.
BASE_URL=https://send.yachmenev.dev

# Public URL of the brand/landing subdomain. Used for README / cross-links.
BRAND_URL=https://yacht.yachmenev.dev

# Path to the SQLite metadata database (WAL-mode file).
DB_PATH=/var/lib/yacht/meta.db

# Default UI language when no cookie / Accept-Language matches. Default: en
DEFAULT_LANG=en

# Default share lifetime in hours (parsed as integer). Default: 24
DEFAULT_EXPIRY_HOURS=24

# Maximum accepted upload size in bytes. Default: 104857600 (100 MiB — matches
# Cloudflare free-tier cap on proxied subdomains).
MAX_UPLOAD_BYTES=104857600

# Storage backend: "r2" (Cloudflare R2 via S3 client) or "local" (disk).
# Default: r2
STORAGE_BACKEND=r2

# Only when STORAGE_BACKEND=local: absolute path to the object root directory.
# Leave unset when using r2.
STORAGE_LOCAL_PATH=/var/lib/yacht/files

# Only when STORAGE_BACKEND=r2: all five are required.
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=yacht-shares
R2_ENDPOINT=https://<r2-account-id>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# Web only (consumed by cmd/web)
# ---------------------------------------------------------------------------

# Address the HTTP server binds to. Default: 127.0.0.1:8080
HTTP_LISTEN=127.0.0.1:8080

# Name of the session cookie. Default: yacht_session
SESSION_COOKIE_NAME=yacht_session

# Session lifetime in days (parsed as integer). Default: 30
SESSION_LIFETIME_DAYS=30

# Telegram bot username (no @) — used by the Login Widget script tag.
TELEGRAM_BOT_USERNAME=yachtshare_bot

# Telegram bot token — used to validate the Login Widget HMAC. Same value as
# the bot binary's TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=<telegram-bot-token>

# ---------------------------------------------------------------------------
# Bot only (consumed by cmd/bot)
# ---------------------------------------------------------------------------

# Telegram bot token — same value as the web binary uses.
# TELEGRAM_BOT_TOKEN=<telegram-bot-token>   # already set above; repeat only if you split env files per binary

# Comma-separated list of admin Telegram user IDs (int64). At least one.
TELEGRAM_ADMIN_IDS=123456789

# Optional webhook URL. When set, the bot runs in webhook mode; when unset
# (or empty) the bot runs in long-poll mode.
WEBHOOK_URL=https://send.yachmenev.dev/bot/webhook
